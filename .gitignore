# ============================================
# CareGo Healthcare Platform — .gitignore
# Monorepo: Backend (Encore.ts) + Flutter + React Web + Admin
# ============================================

# ── Local-only documentation (not for Git) ──
docs-Main/
docs/

# ── OS files ──
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# ── IDE / Editor ──
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
.history/

# ── Node.js / npm / Bun (Backend + Frontend + Admin) ──
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
bun.lockb

# ── Encore.ts Backend ──
backend/encore-local.secrets.json
backend/.encore/
backend/dist/

# ── React Frontends (Vite builds) ──
frontend/dist/
frontend/.vite/
admin-frontend/dist/
admin-frontend/.vite/

# ── Flutter / Dart ──
flutter-app/.dart_tool/
flutter-app/.packages
flutter-app/.pub-cache/
flutter-app/.pub/
flutter-app/build/
flutter-app/.flutter-plugins
flutter-app/.flutter-plugins-dependencies
flutter-app/android/.gradle/
flutter-app/android/local.properties
flutter-app/android/app/debug/
flutter-app/android/app/profile/
flutter-app/android/app/release/
flutter-app/android/key.properties
flutter-app/*.jks
flutter-app/ios/Pods/
flutter-app/ios/.symlinks/

# ── Environment variables ──
.env
.env.local
.env.*.local
*.env

# ── Build artifacts ──
*.apk
*.aab
*.ipa
*.exe
*.dll

# ── Logs ──
*.log
logs/

# ── Docker (local dev volumes) ──
docker-data/
postgres-data/
redis-data/
